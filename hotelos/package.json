{
  "name": "hotelos",
  "private": true,
  "version": "0.1.0",
  "description": "Mobile-first HotelOS monorepo for PMS, compliance, operations, accounting, assets, concierge, and AI tool orchestration.",
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @hotelos/api run dev",
    "dev:ai": "npm --workspace @hotelos/ai-gateway run dev",
    "dev:mobile": "npm --workspace @hotelos/mobile run start",
    "dev:guest-web": "npm --workspace @hotelos/guest-web run dev",
    "preview:demo": "node demo/server.mjs",
    "db:seed:commercial": "npm --workspace @hotelos/database run db:seed:commercial",
    "test": "node --test tests/*.test.mjs",
    "smoke:demo": "node scripts/smoke-demo.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "backup:check": "node scripts/backup-restore-check.mjs",
    "discoverability:check": "node scripts/check-discoverability.mjs",
    "typecheck": "npm --workspaces run typecheck",
    "lint": "npm --workspaces run lint",
    "prepare": "git config core.hooksPath .husky 2>/dev/null || true"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "eslint": "^9.26.0",
    "typescript": "^5.8.0"
  }
}
