DATABASE_URL=postgresql://hotelos:hotelos@localhost:5432/hotelos
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
# audit 2026-06 R2 · #7: set to "true" ONLY in dev/demo environments.
# When false (default), unauthenticated requests are rejected with 401
# regardless of NODE_ENV. Production compose must NOT set this to true.
HOTELOS_ALLOW_DEMO_AUTH=true
ENCRYPTION_KEY=change-me-32-bytes
OBJECT_STORAGE_BUCKET=hotelos-dev
OBJECT_STORAGE_REGION=eu-west-1
OBJECT_STORAGE_ACCESS_KEY=change-me
OBJECT_STORAGE_SECRET_KEY=change-me
AI_PROVIDER_API_KEY=change-me
OCR_PROVIDER_API_KEY=change-me
SPEECH_PROVIDER_API_KEY=change-me
PAYMENT_PROVIDER_SECRET=change-me
WHATSAPP_PROVIDER_TOKEN=change-me
EMAIL_PROVIDER_KEY=change-me
SES_HOSPEDAJES_CLIENT_ID=change-me
SES_HOSPEDAJES_CLIENT_SECRET=change-me
# Compliance ES · modos de envío (sandbox|preproduction|production)
# Para go-live real, cambia a preproduction primero y prueba contra el entorno
# de pruebas oficial antes de pasar a production.
VERIFACTU_MODE=sandbox
VERIFACTU_CERT_PATH=
VERIFACTU_CERT_PASSPHRASE=
VERIFACTU_SOFTWARE_NIF=
VERIFACTU_INSTALL_NUMBER=
SES_HOSPEDAJES_MODE=sandbox
SES_HOSPEDAJES_CERT_PATH=
SES_HOSPEDAJES_CERT_PASSPHRASE=
TBAI_MODE=sandbox
TBAI_CERT_PATH=
TBAI_CERT_PASSPHRASE=
IGIC_MODE=sandbox
IGIC_CERT_PATH=
IGIC_CERT_PASSPHRASE=
APP_PUBLIC_API_URL=http://localhost:3000
# Sentry (vacío = desactivado). Si lo defines, captura errores 5xx en API.
SENTRY_DSN=
# Sentry para admin-web (Vite, inyectado en build).
VITE_SENTRY_DSN=
# Origen público del frontend para CORS en piloto (ej: https://pilot.acme-hotel.com).
PILOT_PUBLIC_ORIGIN=
# Token para el endpoint POST /onboarding/bootstrap (first-run piloto).
# Genera con: openssl rand -hex 32. Después del primer arranque queda obsoleto
# (la guard `count(Organization) === 0` desactiva el endpoint automáticamente).
BOOTSTRAP_TOKEN=

