// =============================================================================
// Tourist tax engine (multi-CCAA, calendar-aware)
// =============================================================================
//
// España es uno de los pocos países donde la tasa turística se decide a nivel
// autonómico Y municipal, con tablas que cambian cada año (a veces a mitad de
// año por aprobación parlamentaria), tarifa por categoría de establecimiento,
// número máximo de noches gravables y exenciones por edad.
//
// El motor cumple 3 funciones:
//   1. Catálogo (`TouristTaxRate`): qué se cobra en cada jurisdicción, válido
//      en un rango de fechas. Soporta tarifas escalonadas por categoría de
//      hotel (eg. Cataluña: 5* lujo > 5* > 4* > 3* > camping...).
//   2. Aplicación (`TouristTaxApplication`): qué se ha aplicado a cada estancia,
//      con quién pagaba y si se cargó al folio. Permite informe trimestral
//      autoliquidable.
//   3. Exenciones (`TouristTaxExemption`): menores, viajes médicos, fuerzas
//      armadas, etc. — distintas por CCAA.

model TouristTaxRate {
  id                 String   @id @default(cuid())
  // Jurisdicción: combinación de país (ES) + comunidad autónoma + municipio
  // (opcional, para tasas municipales como Barcelona o San Sebastián).
  country            String   @default("ES")
  ccaaCode           String   @map("ccaa_code") // p.ej. CAT, BAL, CAN, EUSK
  municipality       String?  // null = aplica a toda la CCAA
  // Categoría del establecimiento — cada CCAA tiene su propio escalado:
  // CAT: lujo_5e, 5_estrellas, 4_estrellas, 3_estrellas, 2_o_menos, camping...
  // BAL: 5_estrellas, 4_estrellas, 3_estrellas, apt_4_4sup, apt_3_2_1...
  // Almacenado como string para flexibilidad. La UI lo presenta como dropdown.
  establishmentClass String   @map("establishment_class")
  // Tarifa en EUR por persona y noche.
  amountPerPersonNight Decimal @db.Decimal(6, 4) @map("amount_per_person_night")
  currency           String   @default("EUR")
  // Validez: la mayoría de tarifas tienen `validUntil = null` (sigue vigente
  // hasta que la sustituya otra).
  validFrom          DateTime @map("valid_from") @db.Date
  validUntil         DateTime? @map("valid_until") @db.Date
  // Máximo de noches por estancia (CAT cobra hasta 7; otras 0 = sin límite).
  maxNightsPerStay   Int      @default(0) @map("max_nights_per_stay")
  // Recarga por temporada alta (p.ej. CAT verano +2 €): expresada como
  // % adicional sobre la tarifa base, aplicado solo entre highSeasonFrom y
  // highSeasonUntil (mm-dd, año actual).
  highSeasonSurcharge Decimal? @db.Decimal(5, 4) @map("high_season_surcharge")
  highSeasonFromMmdd  String?  @map("high_season_from_mmdd")  // "06-15"
  highSeasonUntilMmdd String?  @map("high_season_until_mmdd") // "09-15"
  // Edad mínima gravable. La mayoría 16 años; alguna 0.
  taxableAgeFrom     Int      @default(16) @map("taxable_age_from")
  // Legal source (BOE/DOGC/BOJA reference) for auditability.
  legalSource        String?  @map("legal_source")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([country, ccaaCode, municipality])
  @@index([validFrom, validUntil])
  @@map("tourist_tax_rates")
}

model TouristTaxApplication {
  id                String   @id @default(cuid())
  propertyId        String   @map("property_id")
  reservationId     String   @map("reservation_id")
  folioId           String?  @map("folio_id")
  folioLineId       String?  @map("folio_line_id")
  rateId            String   @map("rate_id")
  // Snapshot of the rate at the moment of application (for reproducibility
  // even if rates table is edited later).
  ccaaCode          String   @map("ccaa_code")
  municipality      String?
  establishmentClass String  @map("establishment_class")
  amountPerPersonNight Decimal @db.Decimal(6, 4) @map("amount_per_person_night")
  currency          String   @default("EUR")
  // Computation details — replicable from these fields alone.
  adultsTaxable     Int      @map("adults_taxable")
  nightsTaxable     Int      @map("nights_taxable")
  totalAmount       Decimal  @db.Decimal(10, 2) @map("total_amount")
  stayFrom          DateTime @map("stay_from") @db.Date
  stayUntil         DateTime @map("stay_until") @db.Date
  exemptionsApplied Json?    @map("exemptions_applied") // [{ guestId, reason }]
  appliedAt         DateTime @default(now()) @map("applied_at")

  @@index([propertyId, stayFrom])
  @@index([reservationId])
  @@map("tourist_tax_applications")
}

model TouristTaxExemption {
  id             String   @id @default(cuid())
  ccaaCode       String   @map("ccaa_code")
  code           String   // "MENORES_16", "MEDICAL_TRIP", "ARMED_FORCES", ...
  description    String
  // Optional age range when applicable.
  ageFrom        Int?     @map("age_from")
  ageTo          Int?     @map("age_to")
  active         Boolean  @default(true)
  legalSource    String?  @map("legal_source")

  @@index([ccaaCode, active])
  @@map("tourist_tax_exemptions")
}

// =============================================================================
// CSRD / ESRS reporting (mandatorio en 2026 para grandes empresas)
// =============================================================================
//
// La Corporate Sustainability Reporting Directive (CSRD) obliga a publicar
// indicadores ESRS (European Sustainability Reporting Standards) en 4 áreas:
//   E (Environment): Scope 1/2/3 CO2, agua, energía, residuos.
//   S (Social): plantilla, accidentes, brecha salarial, diversidad.
//   G (Governance): conflictos de interés, anti-corrupción.
//   General: cadena de valor, materialidad.
//
// Grandes empresas (>250 empleados, >50M€ facturación, >25M€ balance) deben
// reportar con datos 2025 antes de fin de 2026. Las cadenas hoteleras
// españolas medianas (Meliá, NH, RIU…) entran en este perímetro.
//
// Este módulo solo modela los datos primarios; el cálculo de indicadores y la
// exportación al formato XBRL/iXBRL queda en el servicio.

model EsrsIndicator {
  id              String   @id @default(cuid())
  propertyId      String?  @map("property_id")
  organizationId  String   @map("organization_id")
  /** Ejercicio: "2025", "2026". */
  fiscalYear      String   @map("fiscal_year")
  /** Standard ESRS: "ESRS_E1", "ESRS_E2", "ESRS_S1", etc. */
  standardCode    String   @map("standard_code")
  /** Disclosure: "E1-6_GHG_Scope1", "E1-6_GHG_Scope2_LocationBased", "S1-6_Headcount". */
  disclosureCode  String   @map("disclosure_code")
  /** Tipo: NUMERIC | TEXT | BOOLEAN | PERCENTAGE | MONETARY. */
  valueType       String   @map("value_type")
  numericValue    Decimal? @db.Decimal(16, 4) @map("numeric_value")
  textValue       String?  @map("text_value")
  unit            String?  // tCO2e, m3, kWh, EUR, headcount...
  /** Fuente del dato: "manual", "imported_sap", "energy_meter_iot", etc. */
  source          String   @default("manual")
  /** Cualquier metadato adicional (notas, fórmulas, períodos). */
  metadataJson    Json?    @map("metadata_json")
  computedAt      DateTime @default(now()) @map("computed_at")
  reportedAt      DateTime? @map("reported_at")

  @@unique([organizationId, propertyId, fiscalYear, disclosureCode])
  @@index([organizationId, fiscalYear, standardCode])
  @@map("esrs_indicators")
}

model EsrsReport {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  fiscalYear      String   @map("fiscal_year")
  status          String   @default("draft") // draft, ready, submitted
  /** Formato exportable: "xbrl_inline", "pdf", "json". */
  format          String   @default("json")
  /** Hash de los datos para integridad — cambia si se altera el contenido. */
  contentHash     String?  @map("content_hash")
  /** Resumen ejecutivo generado: { totalIndicators, completeness%, ... }. */
  summaryJson     Json?    @map("summary_json")
  payloadXbrl     String?  @map("payload_xbrl") @db.Text
  generatedBy     String?  @map("generated_by")
  generatedAt     DateTime @default(now()) @map("generated_at")
  submittedAt     DateTime? @map("submitted_at")

  @@unique([organizationId, fiscalYear])
  @@index([organizationId, status])
  @@map("esrs_reports")
}

// =============================================================================
// OAuth2 / Marketplace público — emisión de tokens para apps de terceros
// =============================================================================
//
// Apaleo y Mews siguen este patrón: la cadena hotelera autoriza una "App"
// (RoomDiary, un CRM, un BI...) que recibe scopes específicos y puede consumir
// la API del PMS en nombre del hotel.
//
// Flujo soportado:
//   1. Authorization Code + PKCE — la App redirige al hotel a /oauth/authorize.
//   2. Client Credentials — para integraciones server-to-server (typical para
//      partners empresariales).
//
// Tokens almacenados con hash; refresh tokens rotativos.

model OAuthAuthorizationCode {
  id              String   @id @default(cuid())
  appId           String   @map("app_id")
  organizationId  String   @map("organization_id")
  propertyId      String?  @map("property_id")
  userId          String?  @map("user_id")
  codeHash        String   @unique @map("code_hash")
  codeChallenge   String?  @map("code_challenge")
  codeChallengeMethod String? @map("code_challenge_method")
  redirectUri     String   @map("redirect_uri")
  scopes          String[]
  expiresAt       DateTime @map("expires_at")
  consumedAt      DateTime? @map("consumed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([appId, expiresAt])
  @@map("oauth_authorization_codes")
}

model OAuthToken {
  id              String   @id @default(cuid())
  appId           String   @map("app_id")
  organizationId  String   @map("organization_id")
  propertyId      String?  @map("property_id")
  userId          String?  @map("user_id")
  /** "access" | "refresh". */
  kind            String
  tokenHash       String   @unique @map("token_hash")
  scopes          String[]
  expiresAt       DateTime @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  /** Cuando un refresh token genera uno nuevo, lo encadenamos. */
  rotatedFromId   String?  @map("rotated_from_id")
  lastUsedAt      DateTime? @map("last_used_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([appId, kind, expiresAt])
  @@index([tokenHash])
  @@map("oauth_tokens")
}

model MarketplaceListing {
  id              String   @id @default(cuid())
  appId           String   @unique @map("app_id")
  publishedAt     DateTime? @map("published_at")
  status          String   @default("draft") // draft | review | published | unlisted
  category        String   // crm, channel_manager, payments, accounting, smart_lock, energy, etc.
  /** Snippet visible en el catálogo. */
  tagline         String
  description     String   @db.Text
  iconUrl         String?  @map("icon_url")
  screenshotsJson Json?    @map("screenshots_json")
  pricing         String?  // "free" | "freemium" | "paid" | "contact_sales"
  privacyUrl      String?  @map("privacy_url")
  termsUrl        String?  @map("terms_url")
  /** Apps verificadas tienen badge. */
  verified        Boolean  @default(false)
  installsCount   Int      @default(0) @map("installs_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status, category])
  @@map("marketplace_listings")
}

model AppInstallation {
  id              String   @id @default(cuid())
  appId           String   @map("app_id")
  organizationId  String   @map("organization_id")
  propertyId      String?  @map("property_id")
  scopes          String[]
  installedAt     DateTime @default(now()) @map("installed_at")
  uninstalledAt   DateTime? @map("uninstalled_at")
  installedByUserId String? @map("installed_by_user_id")

  @@unique([appId, organizationId, propertyId])
  @@index([organizationId, propertyId])
  @@map("app_installations")
}

model RateChangeJournal {
  id            String   @id @default(cuid())
  propertyId    String
  userId        String
  userEmail     String?
  timestamp     DateTime @default(now())
  changesCount  Int
  changesJson   Json     // detalle de celdas afectadas
  reason        String?
  pushedTo      String[] @default([])  // channel ids
  pushStatus    String   @default("draft") // draft|pushed|failed
  property      Property @relation(fields: [propertyId], references: [id])
  @@index([propertyId, timestamp])
  @@map("rate_change_journals")
}
