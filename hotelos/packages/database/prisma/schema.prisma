// On-the-books (OTB) captured "as of" a capture date, per stay date. Lets us
// compute real PACE (build-up vs a prior capture / STLY) and PICKUP (net new
// bookings in a window). Captured nightly; one row per (property, capture, stay).
model RevenuePaceSnapshot {
  id           String   @id @default(cuid())
  propertyId   String   @map("property_id")
  captureDate  DateTime @map("capture_date") @db.Date
  stayDate     DateTime @map("stay_date") @db.Date
  roomsOtb     Int      @default(0) @map("rooms_otb")
  revenueOtb   Decimal  @default(0) @map("revenue_otb") @db.Decimal(12, 2)
  reservations Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([propertyId, captureDate, stayDate])
  @@index([propertyId, stayDate])
  @@index([propertyId, captureDate])
  @@map("revenue_pace_snapshots")
}

// Forecast accuracy log: a stored forecast value vs the realized actual for a
// stay date, with absolute/percentage error. Powers the accuracy view.
model ForecastAccuracy {
  id            String   @id @default(cuid())
  propertyId    String   @map("property_id")
  stayDate      DateTime @map("stay_date") @db.Date
  metric        String
  segment       String?
  forecastValue Decimal  @map("forecast_value") @db.Decimal(14, 4)
  actualValue   Decimal  @map("actual_value") @db.Decimal(14, 4)
  absError      Decimal  @map("abs_error") @db.Decimal(14, 4)
  pctError      Decimal? @map("pct_error") @db.Decimal(8, 2)
  modelVersion  String?  @map("model_version")
  capturedAt    DateTime @default(now()) @map("captured_at")

  @@unique([propertyId, stayDate, metric, segment])
  @@index([propertyId, stayDate])
  @@map("forecast_accuracy")
}

// A rate-shop run: captures competitor rates into CompetitorRateSnapshot. The
