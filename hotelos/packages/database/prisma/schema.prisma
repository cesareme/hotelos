  finishedAt  DateTime? @map("finished_at")

  @@index([propertyId, shopDate])
  @@map("rate_shop_jobs")
}

// A pricing rule: when occupancy falls in [min,max], adjust the BAR by a percent
// or fixed amount, clamped to [minPrice,maxPrice]. Evaluated by priority asc.
