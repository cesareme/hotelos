model Folio {
  id            String      @id @default(cuid())
  reservationId String      @map("reservation_id")
  guestId       String?     @map("guest_id")
  status        FolioStatus @default(open)
  currency      String      @default("EUR")
  // Label distinguishes one folio from another on the same reservation. The
  // first folio is "guest" by convention; adding a "company" folio lets the
  // routing engine split charges between payers. Free-form so chains can use
  // their own labels (e.g. "F&B", "Travel agent").
  label         String      @default("guest")
  isPrimary     Boolean     @default(true) @map("is_primary")
  deletedAt     DateTime?   @map("deleted_at")

  // Relations (added in 2026 audit P1-3 to enable typed `include` and reduce
  // N+1 queries in folio routing / dashboards).
  reservation   Reservation @relation("ReservationFolios", fields: [reservationId], references: [id], onDelete: Cascade)
  lines         FolioLine[]
  payments      Payment[]

  @@index([reservationId])
  // Hot-fix perf: filter the open vs closed folios on a reservation
  // (folio routing & balance views).
  @@index([reservationId, status])
  @@index([deletedAt])
  @@map("folios")
}

// FolioRoutingRule — when a new FolioLine of a given type is posted on a
// reservation's PRIMARY folio, automatically reroute it to a specific
// secondary folio. Standard PMS pattern: "Room goes to guest folio; F&B and
// minibar go to the company folio". Rules are evaluated in priority order.
//   sourceType: free text matching FolioLine.type (e.g. "room", "tax",
//               "breakfast", "minibar", "adjustment") or "*" for all.
//   targetFolioId: the secondary folio that should receive the line.
model FolioRoutingRule {
  id            String   @id @default(cuid())
  reservationId String   @map("reservation_id")
  sourceType    String   @map("source_type")
  targetFolioId String   @map("target_folio_id")
  priority      Int      @default(0)
  active        Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([reservationId, active, priority])
  @@map("folio_routing_rules")
}

model FolioLine {
