// CancellationPolicy — defines free-cancel window + penalty on late cancel and
// no-show. Wired to Reservation via cancellationPolicyId/code. The engine in
// modules/pms/cancellation-policy.service.ts uses these to auto-post fees on
// cancel (transitionReservation) and on no-show (night-audit step).
// TourOperator — B2B partner (Hotelbeds, TUI, FTI, JetTours, Iberostar B2B…)
// who negotiates room blocks with the hotel. Lives at organization level
// because a chain typically negotiates a single contract per TT.OO. across
// multiple properties. Per-property terms are captured in the Allotment.
model TourOperator {
  id                   String   @id @default(cuid())
  organizationId       String   @map("organization_id")
  code                 String
  name                 String
  taxId                String?  @map("tax_id")
  contactEmail         String?  @map("contact_email")
  contactPhone         String?  @map("contact_phone")
  defaultCommissionPct Decimal? @map("default_commission_pct") @db.Decimal(5, 2)
  paymentTermsDays     Int      @default(30) @map("payment_terms_days")
  currency             String   @default("EUR")
  active               Boolean  @default(true)
  notes                String?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, code])
  @@index([organizationId, active])
  @@map("tour_operators")
}

// Allotment — a contracted block of rooms reserved for a TourOperator during a
// validity window, broken down per day (AllotmentDay). The "release period"
// returns unused inventory to the hotel's general availability N days before
// the use date (e.g. 14 days), making the engine usable for any market.
model Allotment {
  id              String   @id @default(cuid())
  propertyId      String   @map("property_id")
  tourOperatorId  String?  @map("tour_operator_id")
  channelId       String?  @map("channel_id")
  code            String
  name            String
  roomTypeId      String   @map("room_type_id")
  ratePlanId      String?  @map("rate_plan_id")
  validFrom       DateTime @map("valid_from") @db.Date
  validTo         DateTime @map("valid_to") @db.Date
  totalRooms      Int      @map("total_rooms")
  releaseDays     Int      @default(14) @map("release_days")
  contractedRate  Decimal? @map("contracted_rate") @db.Decimal(12, 2)
  currency        String   @default("EUR")
  status          String   @default("active") // draft|active|expired|released|cancelled

  // ────── Industria · campos B2B estándar ──────
  // allotmentType — modelo contractual del cupo (Hotelbeds, TUI, Jet2…)
  //   soft       — release period libera lo no vendido (estándar TT.OO. europeos)
  //   hard       — commit: TT.OO. paga aunque no venda (riesgo financiero del operador)
  //   free_sale  — sin inventario reservado, request-by-request
  allotmentType   String   @default("soft") @map("allotment_type")

  // counterpartyType — naturaleza comercial de la contraparte
  //   tour_operator | bedbank | corporate | ota
  counterpartyType String  @default("tour_operator") @map("counterparty_type")

  // rateType — net rate (operador aplica markup propio) vs commissionable (% comisión)
  //   net | commissionable
  rateType        String   @default("net") @map("rate_type")
  commissionPct   Decimal? @map("commission_pct") @db.Decimal(5, 2)

  // stopSell — botón rojo de cierre rápido (rechaza nuevas reservas vía este cupo).
  //   No toca AllotmentDay; el código de reserva debe filtrar Allotment.stopSell=false.
  stopSell        Boolean  @default(false) @map("stop_sell")

  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([propertyId, code])
  @@index([propertyId, status, validFrom, validTo])
  @@index([tourOperatorId])
  @@map("allotments")
}

// AllotmentDay — the daily granular cuota for a given Allotment.
//   blockedRooms  — capacity contracted for that day
//   pickedUpRooms — rooms already consumed by reservations
//   releasedRooms — rooms automatically returned to general pool because the
//                   release-period window expired before pickup
// Remaining cuota available = blockedRooms − pickedUpRooms − releasedRooms.
model AllotmentDay {
  id             String   @id @default(cuid())
  allotmentId    String   @map("allotment_id")
  date           DateTime @db.Date
  blockedRooms   Int      @map("blocked_rooms")
  pickedUpRooms  Int      @default(0) @map("picked_up_rooms")
  releasedRooms  Int      @default(0) @map("released_rooms")
  notes          String?
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([allotmentId, date])
  @@index([allotmentId])
  @@map("allotment_days")
}

model CancellationPolicy {
  id                String   @id @default(cuid())
  propertyId        String   @map("property_id")
  code              String
  name              String
  description       String?
  // How many hours BEFORE arrival the guest may cancel free of charge.
  // 0 = no free cancellation window (any cancellation triggers the penalty).
  freeCancelHours   Int      @default(48) @map("free_cancel_hours")
  // Penalty when cancelled after the free window:
  //   first_night    — charge the price of the first night
  //   percent        — charge `penaltyValue`% of the total stay
  //   fixed_amount   — charge `penaltyValue` €
  //   all_stay       — charge the full stay total
  //   none           — never penalize
  penaltyType       String   @default("first_night") @map("penalty_type")
  penaltyValue      Decimal? @map("penalty_value") @db.Decimal(12, 2)
  // No-show penalty (applied automatically by the night audit when arrivalDate
  // is past and no check-in happened). Same value set as penaltyType.
  noShowPenaltyType String   @default("first_night") @map("no_show_penalty_type")
  noShowPenaltyValue Decimal? @map("no_show_penalty_value") @db.Decimal(12, 2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([propertyId, code])
  @@index([propertyId, active])
  @@map("cancellation_policies")
}

model Reservation {
  id                   String            @id @default(cuid())
  propertyId           String            @map("property_id")
  code                 String
  channel              String
  status               ReservationStatus @default(draft)
  arrivalDate          DateTime          @map("arrival_date") @db.Date
  departureDate        DateTime          @map("departure_date") @db.Date
  adults               Int               @default(1)
  children             Int               @default(0)
  infants              Int               @default(0)
  childrenAgesJson     Json?             @map("children_ages_json")
  roomsCount           Int               @default(1) @map("rooms_count")
  eta                  String?           // estimated time of arrival "HH:MM"
  etd                  String?           // estimated time of departure "HH:MM"
  roomTypeId           String?           @map("room_type_id")
  assignedRoomId       String?           @map("assigned_room_id")
  ratePlanId           String?           @map("rate_plan_id")
  boardType            String?           @map("board_type") // RO / BB / HB / FB / AI
  marketSegment        String?           @map("market_segment")
  sourceCode           String?           @map("source_code")
  purposeOfStay        String?           @map("purpose_of_stay") // leisure / business / group / other
  guaranteeType        String?           @map("guarantee_type")
  depositAmount        Decimal?          @map("deposit_amount") @db.Decimal(12, 2)
  cancellationPolicyCode String?         @map("cancellation_policy_code")
  billingInstruction   String?           @map("billing_instruction")
  companyName          String?           @map("company_name")
  travelAgentName      String?           @map("travel_agent_name")
  groupCode            String?           @map("group_code")
  externalReference    String?           @map("external_reference") // OTA / channel confirmation no.
  bookerName           String?           @map("booker_name")
  bookerEmail          String?           @map("booker_email")
  specialRequests      String?           @map("special_requests")
  notes                String?
  totalAmount          Decimal           @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency             String            @default("EUR")
  cancellationPolicyId String?           @map("cancellation_policy_id")
  // 2026 audit: PMS field parity with Mews / Opera / Cloudbeds. All optional /
  // defaulted so existing rows remain valid; `bookingSource` complements the
  // pre-existing `sourceCode` (channel) by storing a free-text origin tag.
  bookingSource        String?           @map("booking_source")
  internalNotes        String?           @map("internal_notes")
  estimatedArrivalTime String?           @map("estimated_arrival_time")
  paymentMethod        String?           @map("payment_method")
  depositPaid          Decimal?          @map("deposit_paid") @db.Decimal(12, 2)
  depositDueDate       DateTime?         @map("deposit_due_date") @db.Date
  vipFlag              Boolean           @default(false) @map("vip_flag")
  accessibilityNeeds   String?           @map("accessibility_needs")
  dietaryRequirements  String?           @map("dietary_requirements")
  groupBookingId       String?           @map("group_booking_id")
  createdAt            DateTime          @default(now()) @map("created_at")
  deletedAt            DateTime?         @map("deleted_at")

  // Relations (added in 2026 audit P1-3 / P1-4).
  folios               Folio[]           @relation("ReservationFolios")
  reservationGuests    ReservationGuest[]
  stays                Stay[]

  @@unique([propertyId, code])
  @@index([propertyId, arrivalDate, departureDate])
  @@index([propertyId, status, arrivalDate])
  @@index([propertyId, status, departureDate])
  @@index([propertyId, externalReference])
  @@index([propertyId, code])
  @@index([deletedAt])
  @@map("reservations")
}

