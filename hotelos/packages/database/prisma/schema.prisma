generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  clean
  dirty
  inspected
  occupied
  out_of_order
  out_of_service
}

enum ReservationStatus {
  draft
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
}

enum FolioStatus {
  open
  closed
}

enum PaymentStatus {
  pending
  captured
  refunded
  failed
}

enum InvoiceStatus {
  draft
  issued
  cancelled
  rectified
}

enum JournalStatus {
  draft
  posted
  reversed
}

enum HousekeepingTaskStatus {
  pending
  assigned
  in_progress
  done
  rejected
}

enum WorkOrderStatus {
  open
  assigned
  in_progress
  waiting_vendor
  resolved
  closed
}

enum ComplianceStatus {
  draft
  missing_data
  ready_to_sign
  signed
  ready_to_submit
  queued
  exported
  submitted
  accepted
  rejected
  failed
  annulled
  corrected
  expired
}

enum SubmissionStatus {
  queued
  sent
  accepted
  rejected
  failed
  annulled
  retrying
}

enum ActorType {
  user
  ai
  system
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  legalName String?  @map("legal_name")
  taxId     String?  @map("tax_id")
  country   String   @default("ES")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("organizations")
}

model Property {
  id                    String   @id @default(cuid())
  organizationId        String   @map("organization_id")
  name                  String
  legalName             String?  @map("legal_name")
  address               String?
  municipality          String?
  province              String?
  country               String   @default("ES")
  taxRegion             String?  @map("tax_region")
  timezone              String   @default("Europe/Madrid")
  status                String   @default("open")
  sesHospedajesEnabled  Boolean  @default(false) @map("ses_hospedajes_enabled")
  verifactuEnabled      Boolean  @default(false) @map("verifactu_enabled")
  // Invoice branding: the hotel's logo (URL or data: URI) and a free-text legal
  // disclaimer / footer block printed at the bottom of every invoice (privacy
  // notice, mercantile registry data, payment terms, etc.).
  invoiceLogoUrl        String?  @map("invoice_logo_url")
  invoiceLegalFooter    String?  @map("invoice_legal_footer")
  createdAt             DateTime @default(now()) @map("created_at")

  rateChangeJournals    RateChangeJournal[]

  @@index([organizationId])
  @@map("properties")
}

model User {
  id                   String    @id @default(cuid())
  organizationId       String    @map("organization_id")
  email                String    @unique
  phone                String?
  fullName             String    @map("full_name")
  status               String    @default("active")
  mfaEnabled           Boolean   @default(false) @map("mfa_enabled")
  passwordHash         String?   @map("password_hash")
  // Lockout para defensa anti-brute-force (PILOT-D1)
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  lastLoginAt          DateTime? @map("last_login_at")
  passwordChangedAt    DateTime? @map("password_changed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  themePreference      String    @default("auto") @map("theme_preference")
  accentColor          String    @default("#007aff") @map("accent_color")
  reducedMotion        Boolean   @default(false) @map("reduced_motion")
  highContrast         Boolean   @default(false) @map("high_contrast")

  @@index([organizationId])
  @@map("users")
}

// PasswordResetToken — single-use token for password reset flow (PILOT-D1).
// TTL 15 min, token guardado como hash para que un dump de DB no comprometa
// los reset pendientes. Marca de uso evita replay.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Device {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  deviceName   String   @map("device_name")
  platform     String
  pushToken    String?  @map("push_token")
  trusted      Boolean  @default(false)
  registeredAt DateTime @default(now()) @map("registered_at")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at")

  @@index([userId, trusted])
  @@map("devices")
}

model Session {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  deviceId   String    @map("device_id")
  status     String    @default("active")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  revokedAt  DateTime? @map("revoked_at")

  @@index([userId, status])
  @@map("sessions")
}

model MfaChallenge {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  purpose         String
  status          String   @default("pending")
  deliveryChannel String   @map("delivery_channel")
  codeHash        String?  @map("code_hash")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId, status, expiresAt])
  @@map("mfa_challenges")
}

model Notification {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  userId     String   @map("user_id")
  type       String
  title      String
  body       String
  status     String   @default("unread")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, status, createdAt])
  @@map("notifications")
}

model OfflineSyncRecord {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  deviceId   String   @map("device_id")
  actionJson Json     @map("action_json")
  resultJson Json     @map("result_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([propertyId, deviceId, createdAt])
  @@map("offline_sync_records")
}

model WorkerJobRun {
  id            String    @id @default(cuid())
  jobName       String    @map("job_name")
  queueName     String    @default("default") @map("queue_name")
  payloadJson   Json      @map("payload_json")
  resultJson    Json?     @map("result_json")
  status        String    @default("queued")
  attempts      Int       @default(0)
  lastError     String?   @map("last_error")
  correlationId String?   @map("correlation_id")
  scheduledFor  DateTime? @map("scheduled_for")
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status, scheduledFor])
  @@index([jobName, status])
  @@map("worker_job_runs")
}

model RetentionPolicy {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  propertyId       String?  @map("property_id")
  entityType       String   @map("entity_type")
  mode             String
  retentionMonths  Int?     @map("retention_months")
  legalHoldAllowed Boolean  @default(true) @map("legal_hold_allowed")
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([organizationId, propertyId, entityType])
  @@index([entityType, enabled])
  @@map("retention_policies")
}

model Module {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  category    String
  isCore      Boolean  @default(false) @map("is_core")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([category, isCore])
  @@map("modules")
}

model PropertyModule {
  id                String    @id @default(cuid())
  propertyId        String    @map("property_id")
  moduleId          String    @map("module_id")
  status            String
  configurationJson Json      @default("{}") @map("configuration_json")
  enabledAt         DateTime? @map("enabled_at")
  disabledAt        DateTime? @map("disabled_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([propertyId, moduleId])
  @@index([propertyId, status])
  @@map("property_modules")
}

model ModuleDependency {
  id               String @id @default(cuid())
  moduleId         String @map("module_id")
  requiredModuleId String @map("required_module_id")

  @@unique([moduleId, requiredModuleId])
  @@map("module_dependencies")
}

model ModuleHealthCheck {
  id           String   @id @default(cuid())
  propertyId   String   @map("property_id")
  moduleCode   String   @map("module_code")
  checkCode    String   @map("check_code")
  status       String
  severity     String
  message      String
  metadataJson Json     @default("{}") @map("metadata_json")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([propertyId, moduleCode, checkCode])
  @@map("module_health_checks")
}

model PropertySetupStep {
  id           String    @id @default(cuid())
  propertyId   String    @map("property_id")
  stepCode     String    @map("step_code")
  status       String
  completedAt  DateTime? @map("completed_at")
  completedBy  String?   @map("completed_by")
  metadataJson Json      @default("{}") @map("metadata_json")

  @@unique([propertyId, stepCode])
  @@map("property_setup_steps")
}

model PropertySetupFormSubmission {
  id                   String   @id @default(cuid())
  propertyId           String   @map("property_id")
  formCode             String   @map("form_code")
  status               String   @default("saved")
  payloadJson          Json     @default("{}") @map("payload_json")
  validationErrorsJson Json     @default("[]") @map("validation_errors_json")
  targetEntityType     String?  @map("target_entity_type")
  targetEntityId       String?  @map("target_entity_id")
  createdBy            String?  @map("created_by")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([propertyId, formCode, createdAt])
  @@map("property_setup_form_submissions")
}

model ManualSetupSubmission {
  id                   String   @id @default(cuid())
  propertyId           String   @map("property_id")
  optionCode           String   @map("option_code")
  status               String   @default("saved")
  payloadJson          Json     @default("{}") @map("payload_json")
  validationErrorsJson Json     @default("[]") @map("validation_errors_json")
  targetTablesJson     Json     @default("[]") @map("target_tables_json")
  inputCategoriesJson  Json     @default("[]") @map("input_categories_json")
  completionChecksJson Json     @default("[]") @map("completion_checks_json")
  createdBy            String?  @map("created_by")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([propertyId, optionCode, createdAt])
  @@map("manual_setup_submissions")
}

model PropertyReadinessCheck {
  id                String   @id @default(cuid())
  propertyId        String   @map("property_id")
  checkCode         String   @map("check_code")
  status            String
  severity          String
  message           String
  relatedEntityType String?  @map("related_entity_type")
  relatedEntityId   String?  @map("related_entity_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([propertyId, checkCode])
  @@map("property_readiness_checks")
}

model Department {
  id          String  @id @default(cuid())
  propertyId  String  @map("property_id")
  name        String
  code        String
  description String?
  active      Boolean @default(true)

  @@unique([propertyId, code])
  @@map("departments")
}

model UserDepartment {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  departmentId String  @map("department_id")
  roleLabel    String? @map("role_label")
  active       Boolean @default(true)

  @@unique([userId, departmentId])
  @@map("user_departments")
}

model PropertyComplianceSetting {
  id                      String   @id @default(cuid())
  propertyId              String   @unique @map("property_id")
  country                 String
  taxRegion               String?  @map("tax_region")
  vatRegime               String?  @map("vat_regime")
  tourismTaxRegion        String?  @map("tourism_tax_region")
  sesHospedajesEnabled    Boolean  @default(false) @map("ses_hospedajes_enabled")
  verifactuEnabled        Boolean  @default(false) @map("verifactu_enabled")
  ticketbaiEnabled        Boolean  @default(false) @map("ticketbai_enabled")
  siiEnabled              Boolean  @default(false) @map("sii_enabled")
  b2bEinvoiceEnabled      Boolean  @default(false) @map("b2b_einvoice_enabled")
  configurationJson       Json     @default("{}") @map("configuration_json")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("property_compliance_settings")
}

model InvoiceSequence {
  id           String  @id @default(cuid())
  propertyId   String  @map("property_id")
  sequenceCode String  @map("sequence_code")
  prefix       String?
  nextNumber   Int     @default(1) @map("next_number")
  padding      Int     @default(6)
  invoiceType  String  @map("invoice_type")
  active       Boolean @default(true)

  @@unique([propertyId, sequenceCode])
  @@map("invoice_sequences")
}

model AccountingSetting {
  id                   String   @id @default(cuid())
  organizationId        String   @map("organization_id")
  propertyId            String?  @map("property_id")
  chartTemplate         String?  @map("chart_template")
  fiscalYearStartMonth  Int      @default(1) @map("fiscal_year_start_month")
  configurationJson     Json     @default("{}") @map("configuration_json")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([organizationId, propertyId])
  @@map("accounting_settings")
}

model CostCenter {
  id         String  @id @default(cuid())
  propertyId String  @map("property_id")
  code       String
  name       String
  type       String
  active     Boolean @default(true)

  @@unique([propertyId, code])
  @@map("cost_centers")
}

model PropertyAiSetting {
  id                     String   @id @default(cuid())
  propertyId             String   @unique @map("property_id")
  aiEnabled              Boolean  @default(true) @map("ai_enabled")
  defaultAutomationLevel String   @default("suggest_and_confirm") @map("default_automation_level")
  guestFacingDisclosure  String?  @map("guest_facing_disclosure")
  voiceLocales           String[] @map("voice_locales")
  configurationJson      Json     @default("{}") @map("configuration_json")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("property_ai_settings")
}

model PropertyAiToolSetting {
  id                   String  @id @default(cuid())
  propertyId           String  @map("property_id")
  toolName             String  @map("tool_name")
  enabled              Boolean @default(true)
  automationLevel      String  @default("suggest_and_confirm") @map("automation_level")
  requiresConfirmation Boolean @default(true) @map("requires_confirmation")
  requiresApprovalRole String? @map("requires_approval_role")
  configurationJson    Json    @default("{}") @map("configuration_json")

  @@unique([propertyId, toolName])
  @@map("property_ai_tool_settings")
}

model DocumentTemplate {
  id            String   @id @default(cuid())
  propertyId    String   @map("property_id")
  templateCode  String   @map("template_code")
  name          String
  channel       String
  language      String
  subject       String?
  body          String
  variablesJson Json     @default("{}") @map("variables_json")
  active        Boolean  @default(true)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([propertyId, templateCode, language])
  @@map("document_templates")
}

model QrCode {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  qrValue    String   @map("qr_value")
  purpose    String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([propertyId, entityType, entityId, purpose])
  @@map("qr_codes")
}

model PropertyImport {
  id           String    @id @default(cuid())
  propertyId   String    @map("property_id")
  importType   String    @map("import_type")
  status       String
  previewJson  Json      @default("{}") @map("preview_json")
  errorJson    Json      @default("{}") @map("error_json")
  committedAt  DateTime? @map("committed_at")
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([propertyId, importType, status])
  @@map("property_imports")
}

model BackOfficeAiSuggestion {
  id                  String    @id @default(cuid())
  propertyId          String    @map("property_id")
  userId              String    @map("user_id")
  prompt              String
  status              String
  proposedChangesJson Json      @default("{}") @map("proposed_changes_json")
  requiresConfirmation Boolean  @default(true) @map("requires_confirmation")
  appliedAt           DateTime? @map("applied_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([propertyId, status, createdAt])
  @@map("backoffice_ai_suggestions")
}

model RevenueForecast {
  id                   String   @id @default(cuid())
  propertyId           String   @map("property_id")
  forecastDate         DateTime @map("forecast_date")
  roomTypeId           String?  @map("room_type_id")
  ratePlanId           String?  @map("rate_plan_id")
  channelId            String?  @map("channel_id")
  segment              String?
  expectedOccupancy    Decimal? @map("expected_occupancy") @db.Decimal(5, 2)
  expectedRoomsSold    Decimal? @map("expected_rooms_sold") @db.Decimal(8, 2)
  expectedAdr          Decimal? @map("expected_adr") @db.Decimal(12, 2)
  expectedRevpar       Decimal? @map("expected_revpar") @db.Decimal(12, 2)
  expectedTrevpar      Decimal? @map("expected_trevpar") @db.Decimal(12, 2)
  expectedGoppar       Decimal? @map("expected_goppar") @db.Decimal(12, 2)
  expectedRoomRevenue  Decimal? @map("expected_room_revenue") @db.Decimal(12, 2)
  expectedTotalRevenue Decimal? @map("expected_total_revenue") @db.Decimal(12, 2)
  expectedProfit       Decimal? @map("expected_profit") @db.Decimal(12, 2)
  cancellationProbability Decimal? @map("cancellation_probability") @db.Decimal(5, 2)
  noShowProbability    Decimal? @map("no_show_probability") @db.Decimal(5, 2)
  confidence           Decimal? @db.Decimal(5, 2)
  modelVersion         String?  @map("model_version")
  driversJson          Json     @default("[]") @map("drivers_json")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([propertyId, forecastDate])
  @@map("revenue_forecasts")
}

model RevenueRecommendation {
  id                   String    @id @default(cuid())
  propertyId           String    @map("property_id")
  recommendationType   String    @map("recommendation_type")
  targetDate           DateTime  @map("target_date")
  roomTypeId           String?   @map("room_type_id")
  ratePlanId           String?   @map("rate_plan_id")
  channelId            String?   @map("channel_id")
  currentValueJson     Json      @default("{}") @map("current_value_json")
  recommendedValueJson Json      @default("{}") @map("recommended_value_json")
  expectedImpactJson   Json      @default("{}") @map("expected_impact_json")
  reasonJson           Json      @default("[]") @map("reason_json")
  confidence           Decimal?  @db.Decimal(5, 2)
  riskLevel            String    @default("medium") @map("risk_level")
  status               String    @default("pending")
  approvedBy           String?   @map("approved_by")
  rejectedBy           String?   @map("rejected_by")
  appliedAt            DateTime? @map("applied_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  @@index([propertyId, status, targetDate])
  @@map("revenue_recommendations")
}

model DemandCalendarEvent {
  id             String   @id @default(cuid())
  propertyId     String   @map("property_id")
  name           String
  eventType      String?  @map("event_type")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  expectedImpact String?  @map("expected_impact")
  impactScore    Decimal? @map("impact_score") @db.Decimal(5, 2)
  source         String?
  metadataJson   Json     @default("{}") @map("metadata_json")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([propertyId, startDate, endDate])
  @@map("demand_calendar_events")
}

model ChannelProfitabilitySnapshot {
  id             String   @id @default(cuid())
  propertyId     String   @map("property_id")
  date           DateTime
  channel        String
  grossRevenue   Decimal? @map("gross_revenue") @db.Decimal(12, 2)
  commissionCost Decimal? @map("commission_cost") @db.Decimal(12, 2)
  paymentCost    Decimal? @map("payment_cost") @db.Decimal(12, 2)
  operatingCost  Decimal? @map("operating_cost") @db.Decimal(12, 2)
  netRevenue     Decimal? @map("net_revenue") @db.Decimal(12, 2)
  profit         Decimal? @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([propertyId, date, channel])
  @@map("channel_profitability_snapshots")
}

model RevenueDailySnapshot {
  id                       String   @id @default(cuid())
  propertyId               String   @map("property_id")
  snapshotDate             DateTime @map("snapshot_date")
  roomTypeId               String?  @map("room_type_id")
  ratePlanId               String?  @map("rate_plan_id")
  channelId                String?  @map("channel_id")
  segment                  String?
  market                   String?
  totalOcc                 Int      @default(0) @map("total_occ")
  arrivalRooms             Int      @default(0) @map("arrival_rooms")
  departureRooms           Int      @default(0) @map("departure_rooms")
  compRooms                Int      @default(0) @map("comp_rooms")
  houseUseRooms            Int      @default(0) @map("house_use_rooms")
  dayUseRooms              Int      @default(0) @map("day_use_rooms")
  noShowRooms              Int      @default(0) @map("no_show_rooms")
  oooRooms                 Int      @default(0) @map("ooo_rooms")
  deductIndividualRooms    Int      @default(0) @map("deduct_individual_rooms")
  nonDeductIndividualRooms Int      @default(0) @map("non_deduct_individual_rooms")
  deductGroupRooms         Int      @default(0) @map("deduct_group_rooms")
  nonDeductGroupRooms      Int      @default(0) @map("non_deduct_group_rooms")
  adultsChildren           Int      @default(0) @map("adults_children")
  roomRevenue              Decimal  @default(0) @map("room_revenue") @db.Decimal(12, 2)
  totalRevenue             Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)
  netRoomRevenue           Decimal  @default(0) @map("net_room_revenue") @db.Decimal(12, 2)
  grossOperatingProfit     Decimal? @map("gross_operating_profit") @db.Decimal(12, 2)
  adr                      Decimal? @db.Decimal(12, 2)
  revpar                   Decimal? @db.Decimal(12, 2)
  trevpar                  Decimal? @db.Decimal(12, 2)
  goppar                   Decimal? @db.Decimal(12, 2)
  occupancyPercent         Decimal? @map("occupancy_percent") @db.Decimal(5, 2)
  dataSource               String   @default("system") @map("data_source")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@unique([propertyId, snapshotDate, roomTypeId, ratePlanId, channelId, segment, market])
  @@index([propertyId, snapshotDate])
  @@map("revenue_daily_snapshots")
}

model RevenueForecastSnapshot {
  id                               String   @id @default(cuid())
  propertyId                       String   @map("property_id")
  forecastDate                     DateTime @map("forecast_date")
  roomTypeId                       String?  @map("room_type_id")
  ratePlanId                       String?  @map("rate_plan_id")
  channelId                        String?  @map("channel_id")
  segment                          String?
  market                           String?
  expectedTotalOcc                 Decimal? @map("expected_total_occ") @db.Decimal(8, 2)
  expectedArrivalRooms             Decimal? @map("expected_arrival_rooms") @db.Decimal(8, 2)
  expectedDepartureRooms           Decimal? @map("expected_departure_rooms") @db.Decimal(8, 2)
  expectedCompRooms                Decimal? @map("expected_comp_rooms") @db.Decimal(8, 2)
  expectedHouseUseRooms            Decimal? @map("expected_house_use_rooms") @db.Decimal(8, 2)
