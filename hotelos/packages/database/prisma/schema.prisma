  adjustType   String   @default("percent") @map("adjust_type")
  adjustValue  Decimal  @default(0) @map("adjust_value") @db.Decimal(12, 2)
  minPrice     Decimal? @map("min_price") @db.Decimal(12, 2)
  maxPrice     Decimal? @map("max_price") @db.Decimal(12, 2)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([propertyId, active, priority])
